JWT_SECRET=change-me
ADMIN_KEY=change-me
APP_URL=http://localhost:3000

# Apollo browser login
APOLLO_EMAIL=
APOLLO_PASSWORD=

# Google Drive verification
GOOGLE_SERVICE_ACCOUNT_JSON=
VERIFIER_FOLDER_ID=
VERIFIER_POLL_SECONDS=30
VERIFIER_TIMEOUT_MINUTES=12

# PlusVibe
PLUSVIBE_KEY=
PLUSVIBE_API_BASE=https://api.plusvibe.ai/api/v1

# Optional per-client API keys. Use the workspace id uppercased with non-alphanumerics as underscores.
# Example for workspace 6912ddfef9582848982b9a62:
# PV_KEY_6912DDFEF9582848982B9A62=

# Automation tuning
HEADLESS=true
APOLLO_SCRAPE_PAGES=100
AUTOMATION_DOWNLOAD_DIR=downloads
AUTOMATION_RUN_DIR=automation-runs
